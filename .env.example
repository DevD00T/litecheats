NODE_ENV=development
# If your platform uses lowercase env keys, `node_env` is also supported:
# node_env=development

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL="Litecheats Enquiry <onboarding@resend.dev>"
RESEND_TO_EMAIL=support@litecheats.com
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=litecheats
BOT_TOKEN=1234567890:telegram_bot_token_here
TELEGRAM_BOT_ENABLED=true
TELEGRAM_WEBHOOK_PATH=/telegram-webhook
TELEGRAM_WEBHOOK_BASE_URL=https://litecheats.com
TELEGRAM_WEBHOOK_SECRET_TOKEN=replace_with_random_secret
TELEGRAM_DEV_WEBHOOK_TUNNEL=false
TELEGRAM_DEV_WEBHOOK_TUNNEL_PORT=8080
