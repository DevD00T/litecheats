{
  "name": "litecheats",
  "version": "0.1.0",
  "scripts": {
    "start": "bun run serve",
    "start:desktop": "bun scripts/run-local.ts",
    "dev": "bun scripts/run-local.ts --watch",
    "dev:hmr": "bun run dev",
    "web": "vite --port 5173",
    "web:fullstack": "bun scripts/fullstack-dev.ts",
    "bot:start": "bun ./src/index.ts",
    "app": "USE_WEBVIEW_DEV_SERVER=1 electrobun dev",
    "app:watch": "USE_WEBVIEW_DEV_SERVER=1 electrobun dev --watch",
    "serve": "bun scripts/serve-dist.ts",
    "start:bundled": "vite build && electrobun dev",
    "build": "vite build",
    "build:canary": "vite build && electrobun build --env=canary",
    "build:stable": "vite build && electrobun build --env=stable",
    "build:dmg": "bun litecheats/scripts/create-dmg.mjs",
    "publish:release": "bun scripts/publish-release.ts",
    "release:macos": "bun scripts/release-macos.ts",
    "appbun:create": "bun appbun ${APPBUN_URL:-https://litecheats.com} --name \"${APPBUN_NAME:-Litecheats}\" --out-dir ${APPBUN_OUT_DIR:-./litecheats} --yes",
    "appbun:dmg": "bun appbun ${APPBUN_URL:-https://litecheats.com} --name \"${APPBUN_NAME:-Litecheats}\" --out-dir ${APPBUN_OUT_DIR:-./litecheats} --dmg --yes",
    "appbun:hmr:create": "APPBUN_URL=${APPBUN_URL:-http://localhost:5173} bun run appbun:create",
    "appbun:hmr:run": "APPBUN_URL=${APPBUN_URL:-http://localhost:5173} APPBUN_OUT_DIR=${APPBUN_OUT_DIR:-./litecheats} bun run appbun:hmr:create && bun scripts/run-appbun-hmr.ts",
    "lint": "biome check src shared",
    "lint:fix": "biome check --write src shared"
  },
  "dependencies": {
    "@elysiajs/static": "^1.4.10",
    "electrobun": "^1.16.0",
    "elysia": "^1.4.28",
    "framer-motion": "^12.38.0",
    "gramio": "^0.9.0",
    "gsap": "^3.15.0",
    "mongodb": "^7.2.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react-router-dom": "^7.14.2",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "untun": "^0.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bun": "^1.3.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "appbun": "^0.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
