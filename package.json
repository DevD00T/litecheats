{
  "name": "litecheats",
  "version": "0.1.0",
  "scripts": {
    "start": "bun scripts/run-local.ts",
    "dev": "bun scripts/run-local.ts --watch",
    "dev:hmr": "bun run dev",
    "web": "vite --port 5173",
    "app": "USE_WEBVIEW_DEV_SERVER=1 electrobun dev",
    "app:watch": "USE_WEBVIEW_DEV_SERVER=1 electrobun dev --watch",
    "start:bundled": "vite build && electrobun dev",
    "build": "vite build",
    "build:canary": "vite build && electrobun build --env=canary",
    "build:stable": "vite build && electrobun build --env=stable",
    "appbun:create": "bunx --bun appbun@latest create ${APPBUN_URL:-http://localhost:5173} --name \"Litecheats\" --out-dir ./desktop/litecheats --yes",
    "release:build:mac": "bun scripts/build-release.ts macos",
    "release:build:win": "bun scripts/build-release.ts windows",
    "release:build:linux": "bun scripts/build-release.ts linux",
    "release:build:host": "bun run build:stable",
    "release:build:all": "bun run release:build:host",
    "release:publish": "bun scripts/publish-release.ts",
    "release:mac:publish": "bun run release:build:mac && bun run release:publish",
    "release:win:publish": "bun run release:build:win && bun run release:publish",
    "release:linux:publish": "bun run release:build:linux && bun run release:publish",
    "release:all:publish": "bun run release:build:all && bun run release:publish",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "electrobun": "^1.16.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "mongodb": "^7.2.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react-router-dom": "^7.14.2",
    "resend": "^6.12.2",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bun": "^1.3.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "appbun": "^0.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
